# NanoPay Environment Configuration
# ALL values must be for TESTNET (Arc L1 / Circle Testnet)

# ==============================================================================
# AUTHENTICATION GUIDE:
#
# 1. GEMINI_API_KEY (Google AI Studio)
#    - Get from: https://aistudio.google.com/
#    - Format: AIzaSy...
#
# 2. CIRCLE_API_KEY (Circle Developer Console)
#    - Get from: https://console.circle.com/ -> API & Client Keys
#    - Type: "Standard" or "Restricted" (Must have Wallets & Nanopayments Read/Write)
#    - IMPORTANT: For testnet, use the full string: TEST_API_KEY:uuid:secret
#    - Format: TEST_API_KEY:e11dc...:f4b3d...
#
# 3. WALLET_IDs (Circle Developer Wallets)
#    - Create 3 "Developer-Controlled Wallets" in the Circle Console.
#    - Use the unique Wallet ID (e.g., wlt_...) or the Arc address (arc:0x...).
#    - ensure Coordinator wallet is funded via Arc Testnet Faucet.
# ==============================================================================

# --- Intelligence (Gemini via google-generativeai SDK) ---
# Use low-token defaults for free-tier stability.
GEMINI_API_KEY=.
GEMINI_COORDINATOR_MODEL=gemini-2.5-pro
GEMINI_REPORT_MODEL=gemini-2.5-pro
GEMINI_EXPERT_MODEL=gemini-2.5-flash
GEMINI_DEFAULT_MAX_OUTPUT_TOKENS=220
GEMINI_HARD_MAX_OUTPUT_TOKENS=320
GEMINI_MAX_PROMPT_CHARS=3500
GEMINI_MAX_ATTEMPTS=30
GEMINI_MODEL_POOL_SIZE=30
GEMINI_MAX_REQUESTS_PER_MINUTE=24
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=0.8
GEMINI_DAILY_OUTPUT_TOKEN_BUDGET=12000

# --- Circle Developer Infrastructure ---
# Use the full TEST_API_KEY:uuid:secret format for the Bearer token
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_GATEWAY_API_URL=https://gateway-api-testnet.circle.com
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# --- Agent Wallets (Circle Developer Wallets) ---
COORDINATOR_WALLET_ID=wlt_...
SPECIALIST_A_WALLET_ID=wlt_...  # (Finance/Biotech)
SPECIALIST_B_WALLET_ID=wlt_...  # (Legal/General)
COORDINATOR_WALLET_ADDRESS=0x...
SPECIALIST_A_WALLET_ADDRESS=0x...
SPECIALIST_B_WALLET_ADDRESS=0x...

# --- Arc Network Settings ---
ARC_CHAIN_ID=arc-testnet
# ARC_EXPLORER_URL can be a fixed address URL for UI display,
# or a tx template like https://testnet.arcscan.app/tx/{tx_hash}
ARC_EXPLORER_URL=https://testnet.arcscan.app/address/0xcF1c22178A8F195860581ff18E17337253EDc340
ARC_RPC_URL=https://rpc.testnet.arc.network/

# --- Coordinator Runtime ---
COORDINATOR_LOOP_DELAY_SECONDS=0.2
NANOPAY_CORS_ALLOW_ORIGINS=*
NANOPAY_CORS_ALLOW_CREDENTIALS=false

# --- ERC-8004 (Arc Testnet) ---
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDRESS=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
METADATA_URI=ipfs://bafkreibdi6623n3xpf7ymk62ckb4bo75o3qemwkpfvp5i25j66itxvsoei
COORDINATOR_METADATA_URI=ipfs://bafkreibdi6623n3xpf7ymk62ckb4bo75o3qemwkpfvp5i25j66itxvsoei
SPECIALIST_A_METADATA_URI=ipfs://bafkreibdi6623n3xpf7ymk62ckb4bo75o3qemwkpfvp5i25j66itxvsoei
SPECIALIST_B_METADATA_URI=ipfs://bafkreibdi6623n3xpf7ymk62ckb4bo75o3qemwkpfvp5i25j66itxvsoei

# --- Local Server Ports ---
COORDINATOR_PORT=8000
AGENT_A_PORT=8001
AGENT_B_PORT=8002
